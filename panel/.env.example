SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tcnZvb25reGVrb2d4cmhsYXlzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NjIxNjM2MCwiZXhwIjoyMDkxNzkyMzYwfQ.X2HyacTgUL-d_bhZxZVGM-mzJOnfyU3PZQrls7q4xCw

# ── JWT para QR de check-in ───────────────────────────────
# Generá con: openssl rand -base64 32
QR_JWT_SECRET=cambia-esto-por-un-secreto-muy-largo-y-aleatorio

# ── Email ─────────────────────────────────────────────────
# Deshabilitado en MVP. Se integra en Fase 2.
# RESEND_API_KEY=re_xxxxxxxxxxxx

# ── Mercado Pago — Checkout Pro ───────────────────────────
# Dashboard: mercadopago.com.ar → Credenciales
# El ACCESS_TOKEN solo se usa server-side para crear la preferencia.
# El PUBLIC_KEY se expone al cliente para el botón de pago (Fase 2 si se embebe).
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxx
MERCADOPAGO_PUBLIC_KEY=APP_USR-xxxxxxxxxxxx
# Flujo: POST /api/reserva/[id]/pago → crea preference → redirect al init_point
# MP redirige de vuelta a /reserva/[id]/confirmacion?status=approved|rejected|pending

# ── URLs de la app ────────────────────────────────────────
# En desarrollo local
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PANEL_URL=http://localhost:3001
# En producción (Vercel)
# NEXT_PUBLIC_APP_URL=https://app.reservaya.com
# NEXT_PUBLIC_PANEL_URL=https://panel.reservaya.com

# ── Entorno ───────────────────────────────────────────────
NODE_ENV=development
