NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tcnZvb25reGVrb2d4cmhsYXlzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYyMTYzNjAsImV4cCI6MjA5MTc5MjM2MH0.5Wh7ncN8A0VXa2Qhk1Ix6M9DQKnarebqWWS6sAPEuls

