# ──────────────────────────────────────────────────────────
#  UnToque — Variables de entorno (template)
#  Copiá este archivo a .env.local en cada package (app/ y panel/).
#  Nunca commitear .env.local (está en .gitignore).
# ──────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────
# supabase.com → tu proyecto → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=XXXX_REPLACE_WITH_ANON_KEY

# Solo server-side (webhooks, seeds, migrations). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=XXXX_REPLACE_WITH_SERVICE_ROLE_KEY

# ── JWT para QR de check-in ───────────────────────────────
# Generá con: openssl rand -base64 32
QR_JWT_SECRET=XXXX_REPLACE_WITH_RANDOM_32_BYTES

# ── Mercado Pago — Checkout Pro ───────────────────────────
# Dashboard: mercadopago.com.ar → Credenciales
MERCADOPAGO_ACCESS_TOKEN=APP_USR-XXXX
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXX
# Secreto para validar firmas de webhook (MP Dashboard > Webhooks > Secret)
MP_WEBHOOK_SECRET=XXXX_MP_WEBHOOK_SECRET

# ── Meta WhatsApp Cloud API (Fase 2) ──────────────────────
# META_WHATSAPP_TOKEN=XXXX
# META_WHATSAPP_PHONE_NUMBER_ID=XXXX
# META_WHATSAPP_BUSINESS_ACCOUNT_ID=XXXX

# ── Web Push / VAPID ──────────────────────────────────────
# Generá con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=XXXX_VAPID_PUBLIC
VAPID_PRIVATE_KEY=XXXX_VAPID_PRIVATE
VAPID_SUBJECT=mailto:no-reply@deuntoque.com

# ── Sentry ────────────────────────────────────────────────
# sentry.io → Projects → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=XXXX
SENTRY_ORG=untoque
SENTRY_PROJECT=panel
# Token para subir sourcemaps en build (opcional)
# SENTRY_AUTH_TOKEN=XXXX

# ── Cron jobs / Edge ──────────────────────────────────────
# Random 32 bytes: openssl rand -base64 32
CRON_SECRET=XXXX_CRON_SECRET

# ── URLs ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_PANEL_URL=http://localhost:3001
# Producción:
# NEXT_PUBLIC_APP_URL=https://app.deuntoque.com
# NEXT_PUBLIC_PANEL_URL=https://panel.deuntoque.com

# ── Entorno ───────────────────────────────────────────────
NODE_ENV=development


# ══════════════════════════════════════════════════════════
#  🔐 ROTACIÓN DE SECRETOS — leer antes de ir a producción
# ══════════════════════════════════════════════════════════
#
# El repo anteriormente tuvo credenciales reales en este archivo.
# ANTES de abrir al público hay que:
#
# 1. Supabase > Settings > API > "Reset anon key" y "Reset service_role key"
# 2. Si el schema Supabase no quedó limpio, regenerar JWT secret también
# 3. Regenerar QR_JWT_SECRET con `openssl rand -base64 32`
# 4. Configurar MP Webhook Secret desde el dashboard MP
# 5. Generar VAPID keys: `npx web-push generate-vapid-keys`
# 6. Generar CRON_SECRET con `openssl rand -base64 32`
# 7. Copiar todos los nuevos valores a Vercel > Project Settings > Environment
# 8. Redeploy
#
# Nunca commitear valores reales a este archivo.
